{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "jsx": "react-native",
    "strict": false,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true
  },
  "include": [
    "App.js",
    "index.js",
    "app.config.js",
    "babel.config.js",
    "metro.config.js",
    "src/**/*.js"
  ],
  "exclude": [
    "node_modules",
    "android",
    "ios",
    "assets/web",
    "frontend",
    "backend",
    "milepilot-upload-v2",
    "test-reports",
    "docs"
  ]
}
