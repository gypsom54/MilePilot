{
  "name": "milepilot",
  "version": "1.0.0",
  "private": true,
  "description": "MilePilot — business mileage tracking (Expo native shell + web PWA)",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "start:dev-client": "expo start --dev-client",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "doctor": "npx expo-doctor",
    "sync:expo-web": "node scripts/sync-expo-web.js",
    "prestart": "node scripts/sync-expo-web.js",
    "prebuild": "node scripts/sync-expo-web.js",
    "build:ios:preview": "eas build --platform ios --profile preview",
    "build:ios:production": "eas build --platform ios --profile production",
    "build:android:preview": "eas build --platform android --profile preview",
    "build:android:production": "eas build --platform android --profile production",
    "submit:ios": "eas submit --platform ios --latest --profile production",
    "release:ios": "eas build --platform ios --profile production --non-interactive && eas submit --platform ios --latest --profile production --non-interactive",
    "verify:stabilisation": "node scripts/verify-stabilisation-checklist.js",
    "verify:release": "node scripts/verify-release.js && node scripts/verify-production-boot.js",
    "verify:tracking": "node scripts/verify-tracking-contract.js",
    "test:native-tracking": "node tests/native-tracking-engine.test.js",
    "verify:reports": "node scripts/verify-reports-contract.js",
    "test:tracking": "node tests/tracking-regression.test.js",
    "test:reports": "node tests/reports-regression.test.js",
    "test:summary-collect": "node tests/summary-reports-collect.test.js",
    "test:trips": "node tests/trip-persistence.test.js",
    "test:auto-end": "node tests/trip-auto-end.test.js",
    "test:native-idle": "node tests/native-idle-policy.test.js",
    "test:autopilot": "node tests/autopilot-motion.test.js",
    "test:tracking-mode": "node tests/tracking-mode.test.js",
    "test:mileage-checklist": "node tests/mileage-vital-checklist.test.js",
    "test:subscription": "node tests/subscription.test.js",
    "test:journey-review": "node tests/journey-review.test.js",
    "test:tax-engine": "node tests/mp-tax-engine.test.js",
    "test:ask-milepilot": "node tests/ask-milepilot-service.test.js",
    "test:ask-parity": "node scripts/mp-s5-parity-audit.js",
    "test:production-boot-syntax": "node tests/production-boot-syntax.test.js",
    "test:onboarding-screen2": "node tests/onboarding-screen2.test.js",
    "test:onboarding-screen3": "node tests/onboarding-screen3.test.js",
    "test:business-workspace": "node tests/business-workspace.test.js",
    "test:ai-review": "node tests/ai-mileage-review.test.js",
    "test:vital": "npm run test:production-boot-syntax && npm run verify:tracking && npm run verify:reports && npm run test:mileage-checklist && npm run test:tracking && npm run test:native-idle && npm run test:autopilot && npm run test:reports && npm run test:summary-collect && npm run test:trips && npm run test:auto-end && npm run test:tracking-mode && npm run test:subscription && npm run test:journey-review && npm run test:tax-engine && npm run test:ask-milepilot && npm run test:business-workspace && npm run test:ai-review"
  },
  "dependencies": {
    "expo": "~56.0.12",
    "expo-asset": "~56.0.17",
    "expo-constants": "~56.0.18",
    "expo-dev-client": "~56.0.20",
    "expo-file-system": "~56.0.8",
    "expo-location": "~56.0.18",
    "expo-notifications": "~56.0.18",
    "expo-status-bar": "~56.0.4",
    "expo-system-ui": "~56.0.5",
    "expo-task-manager": "~56.0.19",
    "react": "19.2.3",
    "react-native": "0.85.3",
    "react-native-maps": "1.27.2",
    "react-native-webview": "13.16.1"
  },
  "devDependencies": {
    "babel-preset-expo": "~56.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}
