{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": false
      },
      "android": {
        "buildType": "apk"
      },
      "env": {
        "WEB_APP_URL": "https://app.milepilot.uk/?runtime=expo&build=development&v=8.11.0"
      }
    },
    "preview": {
      "distribution": "internal",
      "ios": {
        "simulator": false
      },
      "android": {
        "buildType": "apk"
      },
      "env": {
        "WEB_APP_URL": "https://app.milepilot.uk/?runtime=expo&build=preview&v=8.11.0"
      }
    },
    "production": {
      "autoIncrement": true,
      "ios": {
        "resourceClass": "m-medium"
      },
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "WEB_APP_URL": "https://app.milepilot.uk/?runtime=expo&build=production&v=8.11.0"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
