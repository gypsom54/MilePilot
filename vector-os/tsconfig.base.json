{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["dom", "dom.iterable", "ES2022"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "paths": {
      "@vector-os/design-system": ["./packages/design-system/src/index.ts"],
      "@vector-os/design-system/*": ["./packages/design-system/src/*"],
      "@vector-os/ui": ["./packages/ui/src/index.ts"],
      "@vector-os/ui/*": ["./packages/ui/src/*"],
      "@vector-os/icons": ["./packages/icons/src/index.tsx"],
      "@vector-os/utils": ["./packages/utils/src/index.ts"],
      "@vector-os/types": ["./packages/types/src/index.ts"]
    }
  }
}
