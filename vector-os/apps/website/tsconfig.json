{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "plugins": [{ "name": "next" }],
    "jsx": "preserve",
    "noEmit": true,
    "allowJs": true,
    "incremental": true,
    "baseUrl": "../..",
    "paths": {
      "@/*": ["./apps/website/src/*"],
      "@vector-platform/tokens": ["./packages/tokens/src/index.ts"],
      "@vector-platform/tokens/*": ["./packages/tokens/src/*"],
      "@vector-platform/ui": ["./packages/ui/src/index.ts"],
      "@vector-platform/ui/*": ["./packages/ui/src/*"],
      "@vector-platform/icons": ["./packages/icons/src/index.tsx"],
      "@vector-platform/utils": ["./packages/utils/src/index.ts"],
      "@vector-platform/types": ["./packages/types/src/index.ts"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
